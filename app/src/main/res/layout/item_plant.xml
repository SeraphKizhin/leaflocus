<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@color/dashboard_panel"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textviewPlantName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/textviewScientificName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="italic"
        android:textColor="@color/leaf_dark"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textviewWaterFrequency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/textviewDifficulty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonAddPlant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/leaf_primary"
        android:text="+ Add to My Collection" />

</LinearLayout>